# ─────────────────────────────────────────────────────────────────────────────
# iMestreDigital — Variáveis de Ambiente
# Copie para .env e preencha com os valores reais do seu VPS/banco.
# NUNCA suba o arquivo .env para o Git.
# ─────────────────────────────────────────────────────────────────────────────

# ── Banco de Dados (MySQL no VPS) ─────────────────────────────────────────────
# Formato: mysql://USUARIO:SENHA@HOST:PORTA/NOME_BANCO?sslmode=disabled
DATABASE_URL="mysql://imestredigital:SUA_SENHA_AQUI@localhost:3306/imestredigital"

# ── Aplicação ─────────────────────────────────────────────────────────────────
NODE_ENV="production"
NEXT_PUBLIC_APP_URL="https://seudominio.com.br"
PORT=3000

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET="TROQUE_POR_UMA_CHAVE_ALEATORIA_FORTE_32+CHARS"
JWT_EXPIRES_IN="1h"
JWT_REFRESH_EXPIRES_IN="7d"

# ── Redis (cache e filas) ─────────────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ── OpenAI / IA (opcional — para o módulo iMestreAI) ─────────────────────────
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4o-mini"

# ── Email (notificações) ──────────────────────────────────────────────────────
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="noreply@seudominio.com.br"

# ── Upload de arquivos ────────────────────────────────────────────────────────
# Local: arquivos ficam em /var/www/imestredigital/uploads
UPLOAD_DIR="/var/www/imestredigital/uploads"
NEXT_PUBLIC_UPLOAD_URL="https://seudominio.com.br/uploads"

# ── Tenant padrão (seed inicial) ──────────────────────────────────────────────
SEED_TENANT_ID="10000000-0000-0000-0000-000000000001"
SEED_ADMIN_EMAIL="admin@suaempresa.com.br"
SEED_ADMIN_SENHA="Troque@123"
SEED_EMPRESA_NOME="Sua Empresa Ltda"
SEED_EMPRESA_CNPJ="00.000.000/0001-00"
