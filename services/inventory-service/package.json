{
  "name": "@imestredigital/inventory-service",
  "version": "0.1.0",
  "private": true,
  "description": "Microserviço de Estoque do iMestreDigital - Multi-depósito com previsão de demanda",
  "scripts": {
    "dev": "nest start --watch",
    "build": "nest build",
    "start": "node dist/main",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,test}/**/*.ts\"",
    "lint:fix": "eslint \"{src,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:unit": "jest --testPathPattern=unit",
    "test:integration": "jest --testPathPattern=integration",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "db:migrate": "prisma migrate dev",
    "db:seed": "prisma db seed",
    "db:generate": "prisma generate",
    "clean": "rm -rf dist node_modules"
  },
  "dependencies": {
    "@nestjs/common": "^10.3.0",
    "@nestjs/core": "^10.3.0",
    "@nestjs/config": "^3.2.0",
    "@nestjs/platform-express": "^10.3.0",
    "@nestjs/swagger": "^7.3.0",
    "@nestjs/microservices": "^10.3.0",
    "@nestjs/terminus": "^10.2.0",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/cache-manager": "^2.2.0",
    "@prisma/client": "^5.13.0",
    "class-validator": "^0.14.0",
    "class-transformer": "^0.5.1",
    "kafkajs": "^2.2.0",
    "cache-manager": "^5.4.0",
    "uuid": "^9.0.0",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.8.0",
    "@imestredigital/types": "*",
    "@imestredigital/config": "*",
    "@imestredigital/logger": "*",
    "@imestredigital/events": "*"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.3.0",
    "@nestjs/testing": "^10.3.0",
    "@imestredigital/typescript-config": "*",
    "@types/node": "^20.12.0",
    "@types/jest": "^29.5.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.0",
    "typescript": "^5.4.0",
    "prisma": "^5.13.0",
    "ts-node": "^10.9.0"
  }
}
