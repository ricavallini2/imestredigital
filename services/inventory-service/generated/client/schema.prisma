// ═══════════════════════════════════════════════════════════════
// iMestreDigital - Schema do Inventory Service
// ═══════════════════════════════════════════════════════════════
// Gerencia estoque multi-depósito, reservas e movimentações.
// ═══════════════════════════════════════════════════════════════

generator client {
  provider = "prisma-client-js"
  output   = "../generated/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// Depósito / armazém / centro de distribuição
model Deposito {
  id       String  @id @default(uuid()) @db.Uuid
  tenantId String  @map("tenant_id") @db.Uuid
  nome     String
  endereco String?
  cidade   String?
  estado   String?
  padrao   Boolean @default(false) // Depósito padrão do tenant
  ativo    Boolean @default(true)

  criadoEm     DateTime @default(now()) @map("criado_em")
  atualizadoEm DateTime @updatedAt @map("atualizado_em")

  saldos        SaldoEstoque[]
  movimentacoes Movimentacao[]

  @@index([tenantId])
  @@map("depositos")
}

/// Saldo de estoque de um produto em um depósito específico
model SaldoEstoque {
  id         String   @id @default(uuid()) @db.Uuid
  tenantId   String   @map("tenant_id") @db.Uuid
  produtoId  String   @map("produto_id") @db.Uuid
  depositoId String   @map("deposito_id") @db.Uuid
  deposito   Deposito @relation(fields: [depositoId], references: [id])

  quantidadeFisica Int @default(0) @map("quantidade_fisica") // Quantidade real no depósito
  reservado        Int @default(0) // Quantidade reservada para pedidos
  estoqueMinimo    Int @default(0) @map("estoque_minimo") // Ponto de pedido

  atualizadoEm DateTime @updatedAt @map("atualizado_em")

  // Disponível = quantidadeFisica - reservado (calculado no service)

  @@unique([tenantId, produtoId, depositoId], name: "tenantId_produtoId_depositoId")
  @@index([tenantId])
  @@index([tenantId, produtoId])
  @@map("saldos_estoque")
}

/// Reserva de estoque para um pedido (impede venda duplicada)
model ReservaEstoque {
  id         String @id @default(uuid()) @db.Uuid
  tenantId   String @map("tenant_id") @db.Uuid
  produtoId  String @map("produto_id") @db.Uuid
  pedidoId   String @map("pedido_id") @db.Uuid
  quantidade Int
  status     String @default("pendente") // pendente, confirmada, cancelada

  criadoEm DateTime @default(now()) @map("criado_em")

  @@index([tenantId, pedidoId])
  @@index([tenantId, produtoId])
  @@map("reservas_estoque")
}

/// Movimentação (histórico de entrada/saída/ajuste/transferência)
model Movimentacao {
  id         String   @id @default(uuid()) @db.Uuid
  tenantId   String   @map("tenant_id") @db.Uuid
  produtoId  String   @map("produto_id") @db.Uuid
  depositoId String   @map("deposito_id") @db.Uuid
  deposito   Deposito @relation(fields: [depositoId], references: [id])

  tipo          String // entrada, saida, ajuste, transferencia
  motivo        String // compra, venda, devolucao, perda, avaria, inventario, transferencia
  quantidade    Int // Positivo = entrada, Negativo = saída
  custoUnitario Int?    @map("custo_unitario") // Em centavos
  observacao    String?

  criadoEm DateTime @default(now()) @map("criado_em")

  @@index([tenantId])
  @@index([tenantId, produtoId])
  @@index([criadoEm])
  @@map("movimentacoes")
}
