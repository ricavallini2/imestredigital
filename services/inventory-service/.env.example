# ═══════════════════════════════════════════════════════════════
# Inventory Service - Variáveis de Ambiente
# ═══════════════════════════════════════════════════════════════

# ─── Servidor ────────────────────────────────────────────────
NODE_ENV=development
PORT=3011

# ─── Banco de Dados ──────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/inventory_service

# ─── JWT (mesmo secret do Auth Service para validar tokens) ──
JWT_SECRET=desenvolvimento-trocar-em-producao

# ─── Kafka ───────────────────────────────────────────────────
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=inventory-service
KAFKA_GROUP_ID=inventory-service-group

# ─── Redis ───────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ─── Alertas de Estoque ───────────────────────────────────────
ALERTA_ESTOQUE_MINIMO_PADRAO=10
ALERTA_ESTOQUE_CRITICO_PADRAO=5

# ─── CORS ────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# ─── Logging ─────────────────────────────────────────────────
LOG_LEVEL=debug
