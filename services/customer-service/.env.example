# ═══════════════════════════════════════════════════════════════
# Customer Service (CRM) - Variáveis de Ambiente
# ═══════════════════════════════════════════════════════════════

# ─── Servidor ────────────────────────────────────────────────
NODE_ENV=development
PORT=3012

# ─── Banco de Dados ──────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/customer_service

# ─── JWT (mesmo secret do Auth Service para validar tokens) ──
JWT_SECRET=desenvolvimento-trocar-em-producao

# ─── Kafka ───────────────────────────────────────────────────
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=customer-service
KAFKA_GROUP_ID=customer-service-group

# ─── Redis ───────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ─── CORS ────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# ─── Logging ─────────────────────────────────────────────────
LOG_LEVEL=debug
