# Aplicação
NODE_ENV=development
PORT=3008
LOG_LEVEL=debug

# Banco de dados
DATABASE_URL=postgresql://usuario:senha@localhost:5432/imestre_ai_db

# OpenAI / LLM
OPENAI_API_KEY=sk-xxx
OPENAI_MODEL=gpt-4
OPENAI_TEMPERATURE=0.7
OPENAI_MAX_TOKENS=2000

# Kafka / Redpanda
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=ai-service
KAFKA_GROUP_ID=ai-service-group
KAFKA_ENABLE_SASL=false

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=1
REDIS_PASSWORD=

# Rate Limiting (requisições por minuto por tenant)
RATE_LIMIT_TOKENS_POR_MINUTO=10000
RATE_LIMIT_REQUISICOES_POR_MINUTO=100

# Sugestões e Cache
CACHE_TTL_SEGUNDOS=3600
CACHE_SUGESTOES_DIAS=7

# Previsão de Demanda
PREVISAO_DIAS_HISTORICO=90
PREVISAO_DIAS_FUTUROS=30

# Serviços externos (para chamadas HTTP se necessário)
ORDER_SERVICE_URL=http://localhost:3000
CATALOG_SERVICE_URL=http://localhost:3001
INVENTORY_SERVICE_URL=http://localhost:3002
FINANCIAL_SERVICE_URL=http://localhost:3003
FISCAL_SERVICE_URL=http://localhost:3004

# Swagger
SWAGGER_ENABLED=true
SWAGGER_PATH=/docs
