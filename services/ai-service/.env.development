# Ambiente: Desenvolvimento Local

NODE_ENV=development
PORT=3008
LOG_LEVEL=debug

# PostgreSQL (Docker)
DATABASE_URL=postgresql://ia_user:senha_segura_123@localhost:5433/imestre_ai_db

# OpenAI (Substituir com chave real para testes)
OPENAI_API_KEY=sk-test-key-desenvolvimento
OPENAI_MODEL=gpt-4
OPENAI_TEMPERATURE=0.7
OPENAI_MAX_TOKENS=2000

# Kafka/Redpanda (Docker)
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=ai-service
KAFKA_GROUP_ID=ai-service-group
KAFKA_ENABLE_SASL=false

# Redis (Docker)
REDIS_HOST=localhost
REDIS_PORT=6380
REDIS_DB=1
REDIS_PASSWORD=

# Rate Limiting
RATE_LIMIT_TOKENS_POR_MINUTO=10000
RATE_LIMIT_REQUISICOES_POR_MINUTO=100

# Cache
CACHE_TTL_SEGUNDOS=3600
CACHE_SUGESTOES_DIAS=7

# Previsão
PREVISAO_DIAS_HISTORICO=90
PREVISAO_DIAS_FUTUROS=30

# Serviços externos (ajustar conforme ambiente local)
ORDER_SERVICE_URL=http://localhost:3000
CATALOG_SERVICE_URL=http://localhost:3001
INVENTORY_SERVICE_URL=http://localhost:3002
FINANCIAL_SERVICE_URL=http://localhost:3003
FISCAL_SERVICE_URL=http://localhost:3004

# Swagger
SWAGGER_ENABLED=true
SWAGGER_PATH=/docs

# Multi-tenancy
DEFAULT_TENANT_ID=tenant-dev-001
