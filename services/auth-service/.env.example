# ═══════════════════════════════════════════════════════════════
# Auth Service - Variáveis de Ambiente
# ═══════════════════════════════════════════════════════════════

# Node Environment
NODE_ENV=development

# API Port
PORT=3001

# ─── Database PostgreSQL ────────────────────────────────────────
DATABASE_URL=postgresql://postgres:password@localhost:5432/auth_service

# ─── JWT Configuração ──────────────────────────────────────────
JWT_SECRET=seu_secret_key_super_secreto_aqui_trocar_em_producao
JWT_EXPIRATION=1h
JWT_REFRESH_EXPIRATION=7

# ─── Kafka ─────────────────────────────────────────────────────
KAFKA_BROKERS=localhost:9092

# ─── CORS ──────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# ─── Email (para recuperação de senha, convites, etc) ────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=seu_email@gmail.com
SMTP_PASS=sua_senha_app_aqui
SMTP_FROM=noreply@imestredigital.com
