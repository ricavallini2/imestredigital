# ═══════════════════════════════════════════════════════════════
# Financial Service - Variáveis de Ambiente
# ═══════════════════════════════════════════════════════════════

# ─── Servidor ────────────────────────────────────────────────────
NODE_ENV=development
PORT=3006

# ─── Banco de Dados ──────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/imestredigital_financial

# ─── Kafka (Redpanda) ────────────────────────────────────────────
KAFKA_BROKERS=localhost:9092
KAFKA_GROUP_ID=financial-service-group

# ─── Redis (Cache) ───────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=1

# ─── JWT ─────────────────────────────────────────────────────────
JWT_SECRET=sua-chave-secreta-muito-segura-trocar-em-producao
JWT_EXPIRATION=1h

# ─── Auth Service (validação de tokens) ──────────────────────────
AUTH_SERVICE_URL=http://localhost:3001

# ─── CORS ────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# ─── Logging ─────────────────────────────────────────────────────
LOG_LEVEL=debug

# ─── Features ────────────────────────────────────────────────────
ENABLE_RECONCILIATION=true
ENABLE_DRE_AUTO_GENERATION=true
