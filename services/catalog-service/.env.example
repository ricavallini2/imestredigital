# ═══════════════════════════════════════════════════════════════
# Catalog Service - Variáveis de Ambiente
# ═══════════════════════════════════════════════════════════════

# ─── Servidor ────────────────────────────────────────────────
NODE_ENV=development
PORT=3010

# ─── Banco de Dados ──────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/catalog_service

# ─── JWT (mesmo secret do Auth Service para validar tokens) ──
JWT_SECRET=desenvolvimento-trocar-em-producao

# ─── Kafka ───────────────────────────────────────────────────
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=catalog-service
KAFKA_GROUP_ID=catalog-service-group

# ─── Redis ───────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ─── Elasticsearch (busca de produtos) ───────────────────────
ELASTICSEARCH_URL=http://localhost:9200
ELASTICSEARCH_INDEX_PRODUTOS=produtos

# ─── MinIO / Storage (imagens de produtos) ───────────────────
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_PRODUTOS=produtos

# ─── CORS ────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# ─── Logging ─────────────────────────────────────────────────
LOG_LEVEL=debug
