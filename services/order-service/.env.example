# ═══════════════════════════════════════════════════════════════
# Order Service (OMS - Gestão de Pedidos)
# ═══════════════════════════════════════════════════════════════

# Servidor
PORT=3005
NODE_ENV=development

# Database
DATABASE_URL=postgresql://imestredigital:senha@localhost:5432/imestredigital_order

# JWT
JWT_SECRET=seu-secret-jwt-mudar-em-producao
JWT_EXPIRES_IN=3600

# Kafka (Redpanda)
KAFKA_BROKERS=localhost:9092

# Redis (Cache)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# Log
LOG_LEVEL=info

# Frete (Placeholder para integração)
MELHOR_ENVIO_API_KEY=seu-api-key
FRENET_API_KEY=seu-api-key
