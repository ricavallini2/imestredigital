# Servidor
NODE_ENV=development
PORT=3007
LOG_LEVEL=debug

# Banco de Dados
DATABASE_URL=postgresql://user:password@localhost:5432/marketplace_db

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Kafka / Redpanda
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=marketplace-service
KAFKA_GROUP_ID=marketplace-service-group

# Mercado Livre
MERCADO_LIVRE_CLIENT_ID=
MERCADO_LIVRE_CLIENT_SECRET=
MERCADO_LIVRE_REDIRECT_URI=http://localhost:3007/api/v1/contas/callback/mercado-livre

# Shopee
SHOPEE_PARTNER_ID=
SHOPEE_PARTNER_KEY=

# Amazon
AMAZON_SELLER_ID=
AMAZON_AWS_ACCESS_KEY=
AMAZON_AWS_SECRET_KEY=
AMAZON_REGION=

# Magalu
MAGALU_API_KEY=

# Americanas
AMERICANAS_API_KEY=

# Segurança
JWT_SECRET=sua-chave-secreta-aqui
JWT_EXPIRE_IN=24h
ENCRYPTION_KEY=sua-chave-de-encriptacao-32-chars

# Sincronização
SINCRONIZACAO_INTERVALO_MINUTOS=30
SINCRONIZACAO_TIMEOUT_MS=300000

# Swagger
SWAGGER_ENABLE=true

# Tenants
TENANT_HEADER=x-tenant-id
