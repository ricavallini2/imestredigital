# ═══════════════════════════════════════════════════════════════
# Notification Service - Variáveis de Ambiente
# ═══════════════════════════════════════════════════════════════

# Node Environment
NODE_ENV=development

# API Port
PORT=3009

# ─── Database PostgreSQL ────────────────────────────────────────
DATABASE_URL=postgresql://postgres:password@localhost:5432/notification_service

# ─── JWT Configuração ──────────────────────────────────────────
JWT_SECRET=seu_secret_key_super_secreto_aqui_trocar_em_producao
JWT_EXPIRATION=1h

# ─── Kafka ─────────────────────────────────────────────────────
KAFKA_BROKERS=localhost:9092

# ─── Redis Cache ────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# ─── SMTP (Email) ───────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=seu_email@gmail.com
SMTP_PASS=sua_senha_app_aqui
SMTP_FROM=noreply@imestredigital.com
SMTP_FROM_NAME=iMestreDigital

# ─── Firebase (Push Notifications) ──────────────────────────────
FIREBASE_PROJECT_ID=seu-projeto-firebase
FIREBASE_PRIVATE_KEY=sua_chave_privada_aqui
FIREBASE_CLIENT_EMAIL=seu-email@seu-projeto.iam.gserviceaccount.com

# ─── Webhooks ───────────────────────────────────────────────────
WEBHOOK_RETRY_ATTEMPTS=3
WEBHOOK_RETRY_DELAY_MS=1000
WEBHOOK_CIRCUIT_BREAKER_THRESHOLD=5

# ─── CORS ──────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://localhost:3001
