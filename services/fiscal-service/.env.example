# ═══════════════════════════════════════════════════════════════
# iMestreDigital - Fiscal Service
# ═══════════════════════════════════════════════════════════════

# ─── Ambiente ────────────────────────────────────────────────
NODE_ENV=development
PORT=3004

# ─── Banco de Dados ──────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/imeestre_fiscal

# ─── JWT (mesmo secret do Auth Service para validar tokens) ──
JWT_SECRET=desenvolvimento-trocar-em-producao

# ─── Kafka ───────────────────────────────────────────────────
KAFKA_BROKERS=localhost:9092

# ─── Redis ───────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ─── CORS ────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# ─── SEFAZ (Ambiente: PRODUCAO ou HOMOLOGACAO) ───────────────
SEFAZ_AMBIENTE=HOMOLOGACAO
SEFAZ_TIMEOUT=30000

# ─── Certificado Digital (Path ou Base64) ───────────────────
CERTIFICADO_DIGITAL_PATH=/path/to/certificate.p12
CERTIFICADO_SENHA=

# ─── NF-e (Configurações padrão) ─────────────────────────────
NFE_SERIE_PADRAO=1
NFE_NUMERO_INICIAL=1
NFCE_SERIE_PADRAO=1
NFCE_NUMERO_INICIAL=1

# ─── Logging ─────────────────────────────────────────────────
LOG_LEVEL=debug
