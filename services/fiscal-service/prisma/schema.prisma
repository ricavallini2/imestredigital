// ═══════════════════════════════════════════════════════════════
// iMestreDigital - Schema do Fiscal Service
// ═══════════════════════════════════════════════════════════════
// Gerencia Notas Fiscais Eletrônicas, configurações fiscais,
// regras de cálculo de impostos, eventos e comunicação SEFAZ.
// ═══════════════════════════════════════════════════════════════

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ═══════════════════════════════════════════════════════════════
// Enums
// ═══════════════════════════════════════════════════════════════

enum TipoNotaFiscal {
  NFE
  NFCE
  NFSE
}

enum StatusNotaFiscal {
  RASCUNHO
  VALIDADA
  TRANSMITIDA
  AUTORIZADA
  REJEITADA
  CANCELADA
  INUTILIZADA
  DENEGADA
}

enum NaturezaOperacao {
  VENDA
  DEVOLUCAO_VENDA
  COMPRA
  DEVOLUCAO_COMPRA
  TRANSFERENCIA
  REMESSA
  RETORNO
  BONIFICACAO
}

/// Nota Fiscal (NF-e, NFS-e, NFC-e)
model NotaFiscal {
  id                   String   @id @default(uuid()) @db.Uuid
  tenantId             String   @map("tenant_id") @db.Uuid
  tipo                 TipoNotaFiscal
  serie                String
  numero               Int
  chaveAcesso          String   @unique // 44 dígitos
  naturezaOperacao     NaturezaOperacao @map("natureza_operacao")
  dataEmissao          DateTime @map("data_emissao")
  dataSaida            DateTime? @map("data_saida")
  status               StatusNotaFiscal @default(RASCUNHO)
  valorTotal           Decimal  @map("valor_total") @db.Decimal(19, 2)
  valorProdutos        Decimal  @map("valor_produtos") @db.Decimal(19, 2)
  valorDesconto        Decimal  @map("valor_desconto") @default(0) @db.Decimal(19, 2)
  valorFrete           Decimal  @map("valor_frete") @default(0) @db.Decimal(19, 2)
  valorSeguro          Decimal  @map("valor_seguro") @default(0) @db.Decimal(19, 2)
  valorOutros          Decimal  @map("valor_outros") @default(0) @db.Decimal(19, 2)
  valorIcms            Decimal  @map("valor_icms") @default(0) @db.Decimal(19, 2)
  valorPis             Decimal  @map("valor_pis") @default(0) @db.Decimal(19, 2)
  valorCofins          Decimal  @map("valor_cofins") @default(0) @db.Decimal(19, 2)
  valorIpi             Decimal  @map("valor_ipi") @default(0) @db.Decimal(19, 2)
  xmlEnvio             String?  @map("xml_envio") @db.Text
  xmlRetorno           String?  @map("xml_retorno") @db.Text
  protocolo            String?
  motivoRejeicao       String?  @map("motivo_rejeicao")
  pedidoId             String?  @map("pedido_id") @db.Uuid
  clienteId            String?  @map("cliente_id") @db.Uuid
  emitente             Json? // Dados do emitente em JSON
  destinatario         Json? // Dados do destinatário em JSON
  informacoesAdicionais String? @map("informacoes_adicionais") @db.Text

  criadoEm             DateTime @default(now()) @map("criado_em")
  atualizadoEm         DateTime @updatedAt @map("atualizado_em")

  itens   ItemNotaFiscal[]
  eventos EventoFiscal[]

  @@unique([tenantId, tipo, serie, numero])
  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, tipo])
  @@index([tenantId, dataEmissao])
  @@index([tenantId, clienteId])
  @@index([chaveAcesso])
  @@map("notas_fiscais")
}

/// Armazena CPF/CNPJ do destinatário para facilitar indexação
/// Extraído do JSON 'destinatario' para uso em queries
model NotaFiscalDest {
  notaFiscalId        String   @id @map("nota_fiscal_id") @db.Uuid
  tenantId            String   @map("tenant_id") @db.Uuid
  destinatarioCpfCnpj String   @map("destinatario_cpf_cnpj")

  @@index([tenantId, destinatarioCpfCnpj])
  @@map("notas_fiscais_dest")
}

/// Item de Nota Fiscal (produtos/serviços)
model ItemNotaFiscal {
  id                  String   @id @default(uuid()) @db.Uuid
  notaFiscalId        String   @map("nota_fiscal_id") @db.Uuid
  notaFiscal          NotaFiscal @relation(fields: [notaFiscalId], references: [id], onDelete: Cascade)
  produtoId           String   @map("produto_id") @db.Uuid
  descricao           String
  ncm                 String
  cfop                String
  unidade             String   // UN, KG, L, etc
  quantidade          Decimal  @db.Decimal(19, 4)
  valorUnitario       Decimal  @map("valor_unitario") @db.Decimal(19, 2)
  valorTotal          Decimal  @map("valor_total") @db.Decimal(19, 2)
  valorDesconto       Decimal  @map("valor_desconto") @default(0) @db.Decimal(19, 2)
  origemMercadoria    String   @map("origem_mercadoria") // 0-Nacional, 1-Estrangeira direita, 2-Estrangeira adquirida
  // CST ICMS: valores válidos 00-60 (régimen ICMS)
  cstIcms             String   @map("cst_icms")
  aliquotaIcms        Decimal  @map("aliquota_icms") @db.Decimal(5, 4) // Em percentual (ex: 0.1800 = 18%)
  baseIcms            Decimal  @map("base_icms") @default(0) @db.Decimal(19, 2)
  valorIcms           Decimal  @map("valor_icms") @default(0) @db.Decimal(19, 2)
  // CST PIS: valores válidos 01-08 (régimen PIS)
  cstPis              String   @map("cst_pis")
  aliquotaPis         Decimal  @map("aliquota_pis") @default(0) @db.Decimal(5, 4)
  basePis             Decimal  @map("base_pis") @default(0) @db.Decimal(19, 2)
  valorPis            Decimal  @map("valor_pis") @default(0) @db.Decimal(19, 2)
  // CST COFINS: valores válidos 01-08 (régimen COFINS)
  cstCofins           String   @map("cst_cofins")
  aliquotaCofins      Decimal  @map("aliquota_cofins") @default(0) @db.Decimal(5, 4)
  baseCofins          Decimal  @map("base_cofins") @default(0) @db.Decimal(19, 2)
  valorCofins         Decimal  @map("valor_cofins") @default(0) @db.Decimal(19, 2)
  // CST IPI: valores válidos 00-05 (régimen IPI)
  cstIpi              String?  @map("cst_ipi")
  aliquotaIpi         Decimal  @map("aliquota_ipi") @default(0) @db.Decimal(5, 4)
  baseIpi             Decimal  @map("base_ipi") @default(0) @db.Decimal(19, 2)
  valorIpi            Decimal  @map("valor_ipi") @default(0) @db.Decimal(19, 2)
  numeroPedido        String?  @map("numero_pedido")
  itemPedido          Int?     @map("item_pedido")

  @@index([notaFiscalId])
  @@index([produtoId])
  @@map("itens_nota_fiscal")
}

enum TipoEventoFiscal {
  CANCELAMENTO
  CARTA_CORRECAO
  INUTILIZACAO
}

enum StatusEventoFiscal {
  PENDENTE
  ENVIADO
  AUTORIZADO
  REJEITADO
}

/// Evento Fiscal (Cancelamento, Carta de Correção, Inutilização)
model EventoFiscal {
  id              String   @id @default(uuid()) @db.Uuid
  notaFiscalId    String   @map("nota_fiscal_id") @db.Uuid
  notaFiscal      NotaFiscal @relation(fields: [notaFiscalId], references: [id], onDelete: Cascade)
  tenantId        String   @map("tenant_id") @db.Uuid
  tipo            TipoEventoFiscal
  sequencia       Int      // Sequência do evento
  dataEvento      DateTime @map("data_evento")
  protocolo       String?  // Protocolo retornado pela SEFAZ
  justificativa   String   // Motivo do cancelamento/CC-e
  xmlEnvio        String?  @map("xml_envio") @db.Text
  xmlRetorno      String?  @map("xml_retorno") @db.Text
  status          StatusEventoFiscal @default(PENDENTE)

  criadoEm        DateTime @default(now()) @map("criado_em")

  @@index([tenantId])
  @@index([notaFiscalId])
  @@map("eventos_fiscais")
}

enum RegimeTributario {
  SIMPLES_NACIONAL
  LUCRO_PRESUMIDO
  LUCRO_REAL
  MEI
}

enum AmbienteSefaz {
  PRODUCAO
  HOMOLOGACAO
}

/// Configuração Fiscal do Tenant
model ConfiguracaoFiscal {
  id                     String   @id @default(uuid()) @db.Uuid
  tenantId               String   @unique @map("tenant_id") @db.Uuid
  regimeTributario       RegimeTributario @map("regime_tributario")
  inscricaoEstadual      String?  @map("inscricao_estadual")
  inscricaoMunicipal     String?  @map("inscricao_municipal")
  cnae                   String?  // Código CNAE principal
  crt                    String?  // Código de Regime Tributário
  ambienteSefaz          AmbienteSefaz @default(HOMOLOGACAO) @map("ambiente_sefaz")
  certificadoDigital     Bytes?   @map("certificado_digital") // Armazenado criptografado
  senhaCertificado       String?  @map("senha_certificado") // Armazenado criptografado
  validadeCertificado    DateTime? @map("validade_certificado")
  serieNfe               String?  @default("1") @map("serie_nfe")
  proximoNumeroNfe       Int      @default(1) @map("proximo_numero_nfe")
  serieNfce              String?  @default("1") @map("serie_nfce")
  proximoNumeroNfce      Int      @default(1) @map("proximo_numero_nfce")
  tokenCsc               String?  @map("token_csc") // Token para NFC-e
  idCsc                  String?  @map("id_csc") // ID CSC para NFC-e

  criadoEm               DateTime @default(now()) @map("criado_em")
  atualizadoEm           DateTime @updatedAt @map("atualizado_em")

  @@map("configuracoes_fiscais")
}

/// Regra Fiscal (Classificação de impostos por NCM, CFOP, UF, etc)
model RegraFiscal {
  id                String   @id @default(uuid()) @db.Uuid
  tenantId          String   @map("tenant_id") @db.Uuid
  nome              String
  descricao         String?
  ncm               String   // Código NCM (8 dígitos)
  cfop              String   // Código CFOP
  cstIcms           String   @map("cst_icms")
  aliquotaIcms      Decimal  @map("aliquota_icms") @db.Decimal(5, 4) // Em percentual (ex: 0.1800 = 18%)
  cstPis            String   @map("cst_pis")
  aliquotaPis       Decimal  @map("aliquota_pis") @db.Decimal(5, 4)
  cstCofins         String   @map("cst_cofins")
  aliquotaCofins    Decimal  @map("aliquota_cofins") @db.Decimal(5, 4)
  cstIpi            String?  @map("cst_ipi")
  aliquotaIpi       Decimal  @map("aliquota_ipi") @default(0) @db.Decimal(5, 4)
  ufOrigem          String?  @map("uf_origem") // Se NULL, aplica para todos
  ufDestino         String?  @map("uf_destino")
  regimeTributario  RegimeTributario? @map("regime_tributario") // Se NULL, aplica para todos
  ativa             Boolean  @default(true)

  criadoEm          DateTime @default(now()) @map("criado_em")
  atualizadoEm      DateTime @updatedAt @map("atualizado_em")

  @@index([tenantId])
  @@index([tenantId, ncm, cfop])
  @@map("regras_fiscais")
}
