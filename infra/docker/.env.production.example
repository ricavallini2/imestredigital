# ═══════════════════════════════════════════════════════════════
# iMestreDigital - Variáveis de Ambiente de Produção
# ═══════════════════════════════════════════════════════════════
# Copie este arquivo para .env.production e preencha os valores.
#   cp .env.production.example .env.production
#
# IMPORTANTE: Nunca commit o .env.production no git!
# ═══════════════════════════════════════════════════════════════

# ─── Geral ─────────────────────────────────────────────────
APP_VERSION=latest
DOMAIN=seudominio.com.br
NODE_ENV=production

# ─── URLs Públicas ─────────────────────────────────────────
NEXT_PUBLIC_API_URL=https://seudominio.com.br/api
NEXT_PUBLIC_APP_URL=https://seudominio.com.br

# ─── PostgreSQL ────────────────────────────────────────────
POSTGRES_USER=imestredigital
POSTGRES_PASSWORD=TROQUE_POR_SENHA_FORTE_AQUI
POSTGRES_DB=imestredigital

# ─── Redis ─────────────────────────────────────────────────
REDIS_PASSWORD=TROQUE_POR_SENHA_FORTE_AQUI

# ─── JWT (Auth Service) ───────────────────────────────────
# Gere com: openssl rand -base64 64
JWT_SECRET=TROQUE_POR_CHAVE_SEGURA_AQUI
JWT_REFRESH_SECRET=TROQUE_POR_OUTRA_CHAVE_SEGURA_AQUI

# ─── IA / LLM ─────────────────────────────────────────────
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ─── Email (SMTP) ─────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# ─── SSL (Let's Encrypt) ──────────────────────────────────
CERTBOT_EMAIL=seu@email.com

# ─── Observabilidade (opcional) ────────────────────────────
GRAFANA_PASSWORD=admin

# ─── Storage S3 (opcional - MinIO) ────────────────────────
MINIO_USER=minioadmin
MINIO_PASSWORD=TROQUE_POR_SENHA_FORTE_AQUI
